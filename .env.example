# 이 파일을 복사해 .env 로 만들고 실제 값을 채워 넣으세요.
# cp .env.example .env
# .env 는 .gitignore 에 등록되어 있어 커밋되지 않습니다.

# 네이버 검색/데이터랩 API (openapi.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 유튜브 Data API
YOUTUBE_API_KEY=

# 국가법령정보센터 Open API (law.go.kr) — OC 파라미터에 사용되는 값
LAW_API_KEY=

# Mistral AI API (전처리·스코어링·초안 생성)
MISTRAL_API_KEY=

# 담당자 알림용 Slack Incoming Webhook
SLACK_WEBHOOK_URL=
